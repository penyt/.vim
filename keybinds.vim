" --- Basic keybinds ---


" Set leader key
let mapleader = " "

nnoremap <leader>b :Ex<CR>
nnoremap <leader>op :Lexplore<CR>

" Reload vimrc 
nnoremap <leader>rl :source ~/.vimrc<CR>



" --- Plugins ---
